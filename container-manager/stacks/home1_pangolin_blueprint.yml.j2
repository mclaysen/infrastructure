public-resources:
  nas2:
    name: Synology NAS
    protocol: http
    full-domain: nas2.{{ domain }}
    host-header: nas2.{{ domain }}
    tls-server-name: nas2.{{ domain }}
    targets:
      - site: alienated-giant-girdled-lizard
        hostname: {{reverse_proxy_ip}}
        method: https
        port: 443
        healthcheck:
          method: GET
          scheme: https
          hostname: 192.168.86.103
          port: 5001
          path: /webapi/entry.cgi?api=SYNO.API.Info&version=1&method=query&query=SYNO.Core.System
          interval: 30
          timeout: 5
          unhealthy-interval: 15
          enabled: true
  hass:
    name: Home assistant
    protocol: http
    full-domain: hass.{{ domain }}
    host-header: hass.{{ domain }}
    tls-server-name: hass.{{ domain }}
    targets:
      - site: alienated-giant-girdled-lizard
        hostname: {{reverse_proxy_ip}}
        method: https
        port: 443
        healthcheck:
          method: GET
          scheme: http
          hostname: 192.168.86.78
          port: 8123
          path: /manifest.json
          interval: 30
          timeout: 5
          unhealthy-interval: 15
          enabled: true
  kvm:
    name: KVM Management for home server
    protocol: http
    full-domain: kvm.{{ domain }}
    host-header: kvm.{{ domain }}
    tls-server-name: kvm.{{ domain }}
    targets:
      - site: alienated-giant-girdled-lizard
        hostname: {{reverse_proxy_ip}}
        method: https
        port: 443
        healthcheck:
          method: GET
          scheme: https
          hostname: 192.168.86.177
          port: 443
          path: /login
          interval: 30
          timeout: 5
          unhealthy-interval: 15
          enabled: true
  media-stats:
    name: Jellyfin Media Stats
    protocol: http
    full-domain: media-stats.{{ domain }}
    host-header: media-stats.{{ domain }}
    tls-server-name: media-stats.{{ domain }}
    targets:
      - site: alienated-giant-girdled-lizard
        hostname: {{reverse_proxy_ip}}
        method: https
        port: 443
        healthcheck:
          method: GET
          scheme: http
          hostname: 192.168.86.202
          port: 3000
          path: /auth/isconfigured
          interval: 30
          timeout: 5
          unhealthy-interval: 15
          enabled: true
  alloy:
    name: Alloy
    protocol: http
    full-domain: alloy.{{ domain }}
    host-header: alloy.{{ domain }}
    tls-server-name: alloy.{{ domain }}
    targets:
      - site: vps-local
        hostname: alloy
        method: http
        port: 12345
    auth:
      sso-enabled: true
      sso-roles:
        - Member
      sso-users:
        - "{{ email_address }}"
  prometheus:
    name: Prometheus
    protocol: http
    full-domain: prometheus.{{ domain }}
    host-header: prometheus.{{ domain }}
    tls-server-name: prometheus.{{ domain }}
    targets:
      - site: vps-local
        hostname: prometheus
        method: http
        port: 9090
    auth: 
      sso-enabled: true
      sso-roles:
        - Member
      sso-users:
        - "{{ email_address }}"
  vps-dashboard:
    name: VPS Dashboard
    protocol: http
    full-domain: vps-dashboard.{{ domain }}
    host-header: vps-dashboard.{{ domain }}
    tls-server-name: vps-dashboard.{{ domain }}
    targets:
      - site: vps-local
        hostname: grafana
        method: http
        port: 3000
  mclaysen-website:
    name: mclaysen.com website
    protocol: http
    full-domain: {{ domain }}
    host-header: {{ domain }}
    tls-server-name: {{ domain }}
    targets:
      - site: alienated-giant-girdled-lizard
        hostname: {{reverse_proxy_ip}}
        method: https
        port: 443
        healthcheck:
          method: GET
          scheme: http
          hostname: 192.168.86.202
          port: 5001
          path: /
          interval: 30
          timeout: 5
          unhealthy-interval: 15
          enabled: true
  media:
    name: Jellyfin Media
    protocol: http
    full-domain: media.{{ domain }}
    host-header: media.{{ domain }}
    tls-server-name: media.{{ domain }}
    targets:
      - site: alienated-giant-girdled-lizard
        hostname: {{reverse_proxy_ip}}
        method: https
        port: 443
        healthcheck:
          method: GET
          scheme: http
          hostname: 192.168.86.202
          port: 8096
          path: /health
          interval: 30
          timeout: 5
          unhealthy-interval: 15
          status: 200
          enabled: true
    rules:
      - action: allow
        match: country
        value: US
        priority: 1
    auth: 
      sso-enabled: true
      sso-roles:
        - Member
      sso-users:
        - "{{ email_address }}"
      
