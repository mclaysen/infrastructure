<domain type='kvm'>
  <name>{{ home_assistant_vm_name }}</name>
  <memory unit='MiB'>{{ home_assistant_memory_mb }}</memory>
  <currentMemory unit='MiB'>{{ home_assistant_memory_mb }}</currentMemory>
  <vcpu placement='static'>{{ home_assistant_vcpus }}</vcpu>
  <os firmware='efi'>
    <type arch='x86_64' machine='{{ home_assistant_machine_type }}'>hvm</type>
    <firmware>
      <feature enabled='no' name='secure-boot'/>
      <feature enabled='no' name='enrolled-keys'/>
    </firmware>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
    <apic/>
  </features>
  <cpu mode='host-passthrough'/>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='{{ home_assistant_disk_path }}'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <mac address='{{ home_assistant_mac_address }}'/>
      <source network='{{ vm_network_bridge_name }}'/>
      <model type='{{ home_assistant_network_model }}'/>
    </interface>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>
    {% for usb_device in usb_devices %}
    <hostdev mode='subsystem' type='usb' managed='yes'>
      <source>
        <address type='usb' bus='{{ usb_device.bus }}' device='{{ usb_device.device }}'/>
      </source>
    </hostdev>
    {% endfor %}
    <graphics type='vnc' port='-1' autoport='yes' listen='127.0.0.1'/>
    <video>
      <model type='vga' vram='16384' heads='1'/>
    </video>
  </devices>
</domain>